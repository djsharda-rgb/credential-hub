{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/kyb-credential.schema.json",
  "title": "KYB Verifiable Credential",
  "description": "JSON Schema for a Know Your Business (KYB) Verifiable Credential.",
  "type": "object",
  "required": [
    "@context",
    "id",
    "type",
    "issuer",
    "issuanceDate",
    "expirationDate",
    "credentialSubject",
    "credentialStatus",
    "proof"
  ],
  "properties": {
    "@context": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 2
    },
    "id": {
      "type": "string",
      "format": "uri"
    },
    "type": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "KYBCredential" }
    },
    "issuer": {
      "type": "string",
      "pattern": "^did:"
    },
    "issuanceDate": {
      "type": "string",
      "format": "date-time"
    },
    "expirationDate": {
      "type": "string",
      "format": "date-time"
    },
    "credentialSubject": {
      "type": "object",
      "required": [
        "id",
        "legalName",
        "jurisdictionOfIncorporation",
        "registrationNumber",
        "dateOfIncorporation",
        "entityType",
        "entityStatus",
        "registeredAddress",
        "beneficialOwners",
        "verificationLevel"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^did:"
        },
        "legalName": {
          "type": "string",
          "minLength": 1
        },
        "tradeName": {
          "type": "string"
        },
        "jurisdictionOfIncorporation": {
          "type": "string",
          "pattern": "^[A-Z]{2}$",
          "description": "ISO 3166-1 alpha-2 country code"
        },
        "registrationNumber": {
          "type": "string",
          "minLength": 1
        },
        "dateOfIncorporation": {
          "type": "string",
          "format": "date"
        },
        "entityType": {
          "type": "string",
          "enum": ["Corporation", "LLC", "Partnership", "SoleProprietorship", "Cooperative", "NonProfit", "Other"]
        },
        "entityStatus": {
          "type": "string",
          "enum": ["Active", "Dissolved", "Suspended", "InLiquidation"]
        },
        "registeredAddress": {
          "type": "object",
          "required": ["streetAddress", "city", "postalCode", "country"],
          "properties": {
            "streetAddress": { "type": "string" },
            "city": { "type": "string" },
            "stateOrProvince": { "type": "string" },
            "postalCode": { "type": "string" },
            "country": {
              "type": "string",
              "pattern": "^[A-Z]{2}$"
            }
          }
        },
        "taxIdentifier": {
          "type": "string"
        },
        "beneficialOwners": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "dateOfBirth", "nationality", "ownershipPercentage", "pep", "sanctionsScreeningPassed"],
            "properties": {
              "name": { "type": "string" },
              "dateOfBirth": { "type": "string", "format": "date" },
              "nationality": { "type": "string", "pattern": "^[A-Z]{2}$" },
              "ownershipPercentage": { "type": "number", "minimum": 0, "maximum": 100 },
              "pep": { "type": "boolean" },
              "sanctionsScreeningPassed": { "type": "boolean" }
            }
          }
        },
        "verificationLevel": {
          "type": "string",
          "enum": ["basic", "standard", "enhanced"]
        }
      }
    },
    "credentialStatus": {
      "type": "object",
      "required": ["id", "type", "statusPurpose", "statusListIndex", "statusListCredential"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "StatusList2021Entry" },
        "statusPurpose": { "const": "revocation" },
        "statusListIndex": { "type": "string" },
        "statusListCredential": { "type": "string", "format": "uri" }
      }
    },
    "proof": {
      "type": "object",
      "required": ["type", "created", "verificationMethod", "proofPurpose", "proofValue"],
      "properties": {
        "type": { "type": "string" },
        "created": { "type": "string", "format": "date-time" },
        "verificationMethod": { "type": "string" },
        "proofPurpose": { "const": "assertionMethod" },
        "proofValue": { "type": "string" }
      }
    }
  }
}
